{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "master",
  "neverConnectToCloud": true,
  "analytics": false,
  "tui": {
    "autoExit": true
  },
  "namedInputs": {
    "default": ["{projectRoot}/package.json", "{workspaceRoot}/pnpm-workspace.yaml"],
    "typescript": [
      "{workspaceRoot}/tsconfig*.json",
      "{projectRoot}/tsconfig*.json",
      "{projectRoot}/build.mjs",
      "{projectRoot}/tsdown.config.ts",
      "{projectRoot}/eslint.config.mjs",
      "{workspaceRoot}/eslint.config.base.mjs",
      "{projectRoot}/src/**/*.{ts,tsx}"
    ],
    "vortex-api": [{ "dependentTasksOutputFiles": "packages/vortex-api/lib/api.d.ts" }]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "typescript", "!{projectRoot}/src/**/*.test.{ts,tsx}"],
      "outputs": ["{projectRoot}/dist/"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "typescript"],
      "outputs": ["{projectRoot}/tsconfig*.tsbuildinfo"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "typescript"],
      "outputs": []
    },
    "lint:quiet": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "typescript"],
      "outputs": []
    }
  }
}
